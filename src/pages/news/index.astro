---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { url } from '../../utils/url';
import { getCollection } from 'astro:content';

const allNews = (await getCollection('news-en')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

const today = allNews[0];
---

<BaseLayout
  title="Daily Global Events - LifeTips"
  description="100 important global news items daily, quick overview of world events"
>
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Daily Global Events', href: '/news/' },
  ]} />

  <h1 class="text-3xl font-bold text-gray-900 mb-4">Daily Global Events</h1>
  <p class="text-gray-500 mb-8">100 important global news items daily</p>

  {today && (
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
      <h2 class="text-xl font-bold text-gray-900 mb-4">{today.data.title}</h2>
      <a href={url(`/news/${today.data.date}/`)} class="text-primary hover:underline">
        View today's full content →
      </a>
    </div>
  )}

  <h2 class="text-xl font-bold text-gray-900 mb-4">History</h2>
  <div class="grid gap-4">
    {allNews.map(news => (
      <a 
        href={url(`/news/${news.data.date}/`)}
        class="block bg-white rounded-lg shadow-sm border border-gray-100 p-4 hover:shadow-md transition-shadow"
      >
        <h3 class="font-medium text-gray-900">{news.data.title}</h3>
        <p class="text-sm text-gray-500 mt-1">{news.data.date}</p>
      </a>
    ))}
  </div>
</BaseLayout>