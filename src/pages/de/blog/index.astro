---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { url } from '../../../utils/url';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog-de')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [...new Set(allPosts.map(post => post.data.category))];
---

<BaseLayout
  title="Alle Beiträge - LifeTips"
  description="Durchsuchen Sie alle praktischen Anleitungen zu KI, Finanzen, Gesundheit, Reisen und Alltagstipps."
>
  <Breadcrumb items={[
    { label: 'Startseite', href: '/de/' },
    { label: 'Alle Beiträge', href: '/de/blog/' },
  ]} />

  <h1 class="text-3xl font-bold text-gray-900 mb-4">Alle Beiträge</h1>
  <p class="text-gray-500 mb-8">Praktische Anleitungen die wirklich funktionieren</p>

  {categories.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-8">
      <a href={url('/de/blog/')} class="px-4 py-2 rounded-full text-sm font-medium bg-primary text-white">Alle</a>
      {categories.map(cat => (
        <a href={url(`/de/category/${cat}/`)} class="px-4 py-2 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-primary/10 hover:text-primary transition-colors">
          {cat}
        </a>
      ))}
    </div>
  )}

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {allPosts.map(post => (
      <PostCard
        title={post.data.title}
        href={url(`/de/blog/${post.id.replace('.md', '')}/`)}
        description={post.data.description}
        date={post.data.pubDate}
        category={post.data.category}
        image={post.data.heroImage}
      />
    ))}
  </div>
</BaseLayout>