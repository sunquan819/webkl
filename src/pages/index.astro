---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { url } from '../utils/url';
import { languages } from '../i18n/utils';
import { getCollection } from 'astro:content';

const zhPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const enPosts = (await getCollection('blog-en')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allPosts = [...enPosts, ...zhPosts].slice(0, 9);
const aiPosts = [...enPosts.filter(p => p.data.category === 'AI'), ...zhPosts.filter(p => p.data.category === '人工智能')];
const financePosts = [...enPosts.filter(p => p.data.category === 'Finance'), ...zhPosts.filter(p => p.data.category === '财经投资')];
const healthPosts = [...enPosts.filter(p => p.data.category === 'Health'), ...zhPosts.filter(p => p.data.category === '健康养生')];

const categories = [...new Set([...enPosts.map(p => p.data.category), ...zhPosts.map(p => p.data.category)])];
---

<BaseLayout
  title="LifeTips - Practical Guides for a Better Life"
  description="Discover practical tips for AI, finance, health, travel, and everyday life. Make every day easier with proven strategies."
>
  <section class="text-center py-12 md:py-20">
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight">
      Practical Guides for<br />
      <span class="text-primary">a Better Life</span>
    </h1>
    <p class="text-lg text-gray-500 max-w-2xl mx-auto mb-4">
      From AI and finance to health and travel — real tips that actually work.
    </p>
    <p class="text-sm text-gray-400 mb-8">
      Languages:
      {Object.entries(languages).map(([code, info]) => (
        <a href={url(`/${code === 'en' ? '' : code}/`)} class="mx-1 hover:text-primary transition-colors">
          {info.flag} {info.name}
        </a>
      ))}
    </p>
    <div class="flex justify-center gap-4 flex-wrap">
      <a href={url('/blog/')} class="bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-secondary transition-colors">
        Browse All Posts
      </a>
      <a href={url('/zh/')} class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-medium hover:bg-gray-100 transition-colors">
        🇨🇳 中文版
      </a>
    </div>
  </section>

  {enPosts.length > 0 && (
    <section class="mb-12 bg-gradient-to-r from-blue-50 to-purple-50 rounded-2xl p-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
          <span>🤖</span> AI & Technology
        </h2>
        <a href={url('/blog/')} class="text-sm text-primary hover:underline">View all →</a>
      </div>
      <p class="text-gray-500 mb-6">ChatGPT, Claude, AI tools guides in English.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {enPosts.slice(0, 4).map(post => (
          <a href={url(`/blog/${post.id.replace('.md', '')}/`)} class="bg-white rounded-lg p-4 border border-gray-100 hover:shadow-md transition-shadow">
            <h3 class="font-medium text-gray-900 mb-2 line-clamp-2">{post.data.title}</h3>
            <p class="text-xs text-gray-500 line-clamp-2">{post.data.description}</p>
            <span class="text-xs text-blue-600 mt-2">🇺🇸 English</span>
          </a>
        ))}
      </div>
    </section>
  )}

  {zhPosts.length > 0 && (
    <section class="mb-12 bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl p-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
          <span>🇨🇳</span> 中文文章
        </h2>
        <a href={url('/zh/')} class="text-sm text-primary hover:underline">查看全部 →</a>
      </div>
      <p class="text-gray-500 mb-6">AI、理财、减肥、省钱等热门话题中文原创。</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
        {zhPosts.slice(0, 5).map(post => (
          <a href={url(`/zh/blog/${post.id.replace('.md', '')}/`)} class="bg-white rounded-lg p-4 border border-gray-100 hover:shadow-md transition-shadow">
            <h3 class="font-medium text-gray-900 mb-2 line-clamp-2 text-sm">{post.data.title}</h3>
            <p class="text-xs text-gray-500 line-clamp-2">{post.data.description}</p>
            <span class="text-xs text-green-600 mt-2">🇨🇳 中文</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mb-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-gray-900">🔥 Latest Posts</h2>
      <a href={url('/blog/')} class="text-sm text-primary hover:underline">View all →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {allPosts.slice(0, 6).map(post => {
        const langPrefix = post.collection === 'blog' ? '/zh' : '';
        return (
          <PostCard
            title={post.data.title}
            href={url(`${langPrefix}/blog/${post.id.replace('.md', '')}/`)}
            description={post.data.description}
            date={post.data.pubDate}
            category={post.data.category}
            image={post.data.heroImage}
          />
        );
      })}
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-8">📂 All Categories</h2>
    <div class="flex flex-wrap gap-3">
      {categories.map(cat => (
        <a href={url(`/blog/`)} class="px-4 py-2 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-primary/10 hover:text-primary transition-colors">
          {cat}
        </a>
      ))}
    </div>
  </section>

  <section class="bg-white rounded-xl p-8 md:p-12 text-center border border-gray-100">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">📬 Get Weekly Tips</h2>
    <p class="text-gray-500 mb-6">Subscribe for practical tips every week.</p>
    <form class="flex gap-3 max-w-md mx-auto" onsubmit="return false;">
      <input type="email" placeholder="Enter your email" class="flex-1 px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:border-primary text-sm" />
      <button type="submit" class="bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-secondary transition-colors text-sm whitespace-nowrap">
        Subscribe
      </button>
    </form>
  </section>
</BaseLayout>