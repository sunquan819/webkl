---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const allNews = (await getCollection('news-zh')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

const today = allNews[0];
---

<BaseLayout
  title="每日全球大事 - LifeTips"
  description="每天100条全球重要新闻汇总，快速了解世界动态"
>
  <Breadcrumb items={[
    { label: '首页', href: '/zh/' },
    { label: '每日全球大事', href: '/zh/news/' },
  ]} />

  <h1 class="text-3xl font-bold text-gray-900 mb-4">每日全球大事</h1>
  <p class="text-gray-500 mb-8">每天100条全球重要新闻，快速了解世界动态</p>

  {today && (
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
      <h2 class="text-xl font-bold text-gray-900 mb-4">{today.data.title}</h2>
      <a href={`/zh/news/${today.data.date}/`} class="text-primary hover:underline">
        查看今日完整内容 →
      </a>
    </div>
  )}

  <h2 class="text-xl font-bold text-gray-900 mb-4">历史记录</h2>
  <div class="grid gap-4">
    {allNews.map(news => (
      <a 
        href={`/zh/news/${news.data.date}/`}
        class="block bg-white rounded-lg shadow-sm border border-gray-100 p-4 hover:shadow-md transition-shadow"
      >
        <h3 class="font-medium text-gray-900">{news.data.title}</h3>
        <p class="text-sm text-gray-500 mt-1">{news.data.date}</p>
      </a>
    ))}
  </div>
</BaseLayout>