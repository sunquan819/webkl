---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { languages } from '../../i18n/utils';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const latestPosts = allPosts.slice(0, 9);
const aiPosts = allPosts.filter(p => p.data.category === '人工智能');
const financePosts = allPosts.filter(p => p.data.category === '财经投资');
const savingPosts = allPosts.filter(p => p.data.category === '省钱攻略');
const categories = [...new Set(allPosts.map(p => p.data.category))];
---

<BaseLayout
  title="LifeTips - 生活妙招与品质生活指南"
  description="发现实用生活妙招，涵盖人工智能、财经投资、健康养生、省钱攻略等话题，让你的生活更加便捷美好。"
>
  <section class="text-center py-12 md:py-20">
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight">
      让生活更美好的<br />
      <span class="text-primary">实用妙招</span>
    </h1>
    <p class="text-lg text-gray-500 max-w-2xl mx-auto mb-4">
      从AI技术到财经投资，从省钱攻略到健康养生，用大白话讲清楚每件事。
    </p>
    <p class="text-sm text-gray-400 mb-8">
      支持语言：
      {Object.entries(languages).map(([code, info]) => (
        <a href={code === 'en' ? '/webkl/' : `/webkl/${code}/`} class="mx-1 hover:text-primary transition-colors">
          {info.flag} {info.name}
        </a>
      ))}
    </p>
    <div class="flex justify-center gap-4 flex-wrap">
      <a href="/webkl/zh/blog/" class="bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-secondary transition-colors">
        浏览全部
      </a>
      <a href="/webkl/" class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-medium hover:bg-gray-100 transition-colors">
        🇺🇸 英文版
      </a>
    </div>
  </section>

  {aiPosts.length > 0 && (
    <section class="mb-12 bg-gradient-to-r from-blue-50 to-purple-50 rounded-2xl p-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
          <span>🤖</span> 人工智能
        </h2>
        <a href="/webkl/zh/category/人工智能/" class="text-sm text-primary hover:underline">查看全部 →</a>
      </div>
      <p class="text-gray-500 mb-6">聊聊AI大模型、省钱攻略、使用技巧，用大白话讲清楚AI那些事。</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
        {aiPosts.slice(0, 5).map(post => (
          <a href={`/webkl/zh/blog/${post.id.replace('.md', '')}/`} class="bg-white rounded-lg p-4 border border-gray-100 hover:shadow-md transition-shadow">
            <h3 class="font-medium text-gray-900 mb-2 line-clamp-2 text-sm">{post.data.title}</h3>
            <p class="text-xs text-gray-500 line-clamp-2">{post.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  {financePosts.length > 0 && (
    <section class="mb-12 bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl p-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
          <span>📈</span> 财经投资
        </h2>
        <a href="/webkl/zh/category/财经投资/" class="text-sm text-primary hover:underline">查看全部 →</a>
      </div>
      <p class="text-gray-500 mb-6">美股ETF、期权交易入门，普通人也能学会的投资技巧。</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {financePosts.slice(0, 4).map(post => (
          <a href={`/webkl/zh/blog/${post.id.replace('.md', '')}/`} class="bg-white rounded-lg p-4 border border-gray-100 hover:shadow-md transition-shadow">
            <h3 class="font-medium text-gray-900 mb-2 line-clamp-2">{post.data.title}</h3>
            <p class="text-xs text-gray-500 line-clamp-2">{post.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  {savingPosts.length > 0 && (
    <section class="mb-12 bg-gradient-to-r from-yellow-50 to-orange-50 rounded-2xl p-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
          <span>💰</span> 省钱攻略
        </h2>
        <a href="/webkl/zh/category/省钱攻略/" class="text-sm text-primary hover:underline">查看全部 →</a>
      </div>
      <p class="text-gray-500 mb-6">日常省钱技巧、旅行省钱方法、如何从低收入开始攒钱。</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {savingPosts.slice(0, 3).map(post => (
          <a href={`/webkl/zh/blog/${post.id.replace('.md', '')}/`} class="bg-white rounded-lg p-4 border border-gray-100 hover:shadow-md transition-shadow">
            <h3 class="font-medium text-gray-900 mb-2 line-clamp-2">{post.data.title}</h3>
            <p class="text-xs text-gray-500 line-clamp-2">{post.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mb-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-gray-900">🔥 最新文章</h2>
      <a href="/webkl/zh/blog/" class="text-sm text-primary hover:underline">查看全部 →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {latestPosts.slice(0, 6).map(post => (
        <PostCard
          title={post.data.title}
href={`/webkl/zh/blog/${post.id.replace('.md', '')}/`}
          description={post.data.description}
          date={post.data.pubDate}
          category={post.data.category}
          image={post.data.heroImage}
        />
      ))}
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-8">📂 全部分类</h2>
    <div class="flex flex-wrap gap-3">
      {categories.map(cat => (
        <a href={`/webkl/zh/category/${cat}/`} class="px-4 py-2 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-primary/10 hover:text-primary transition-colors">
          {cat}
        </a>
      ))}
    </div>
  </section>

  <section class="bg-white rounded-xl p-8 md:p-12 text-center border border-gray-100">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">📬 每周获取生活灵感</h2>
    <p class="text-gray-500 mb-6">订阅我们，第一时间获取最新生活妙招和实用技巧。</p>
    <form class="flex gap-3 max-w-md mx-auto" onsubmit="return false;">
      <input
        type="email"
        placeholder="输入你的邮箱地址"
        class="flex-1 px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:border-primary text-sm"
      />
      <button type="submit" class="bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-secondary transition-colors text-sm whitespace-nowrap">
        订阅
      </button>
    </form>
  </section>
</BaseLayout>