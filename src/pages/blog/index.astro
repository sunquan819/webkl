---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [...new Set(allPosts.map(post => post.data.category))];
---

<BaseLayout
  title="全部文章"
  description="浏览 LifeTips 所有生活妙招文章，涵盖家居收纳、健康养生、美食烹饪等话题。"
>
  <Breadcrumb items={[
    { label: '首页', href: '/' },
    { label: '全部文章', href: '/blog/' },
  ]} />

  <h1 class="text-3xl font-bold text-gray-900 mb-4">全部文章</h1>
  <p class="text-gray-500 mb-8">发现实用的生活妙招和品质生活灵感</p>

  {categories.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-8">
      <a href="/blog/" class="px-4 py-2 rounded-full text-sm font-medium bg-primary text-white">全部</a>
      {categories.map(cat => (
        <a href={`/category/${cat}/`} class="px-4 py-2 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-primary/10 hover:text-primary transition-colors">
          {cat}
        </a>
      ))}
    </div>
  )}

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {allPosts.map(post => (
      <PostCard
        title={post.data.title}
        href={`/blog/${post.id}/`}
        description={post.data.description}
        date={post.data.pubDate}
        category={post.data.category}
        image={post.data.heroImage}
      />
    ))}
  </div>
</BaseLayout>
