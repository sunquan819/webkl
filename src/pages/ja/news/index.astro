---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const allNews = (await getCollection('news-ja')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
---

<BaseLayout title="毎日ニュース - LifeTips" description="毎日世界重要ニュース100選">
  <Breadcrumb items={[{ label: 'ホーム', href: '/ja/' }, { label: '毎日ニュース', href: '/ja/news/' }]} />
  <h1 class="text-3xl font-bold text-gray-900 mb-4">毎日ニュース</h1>
  <div class="grid gap-4">
    {allNews.map(news => (
      <a href={`/ja/news/${news.data.date}/`} class="block bg-white rounded-lg p-4 hover:shadow-md">
        <h3 class="font-medium">{news.data.title}</h3>
        <p class="text-sm text-gray-500">{news.data.date}</p>
      </a>
    ))}
  </div>
</BaseLayout>