---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags?: string[];
  author?: string;
  heroImage?: string;
}

const { title, description, pubDate, updatedDate, category, tags = [], author = 'LifeTips', heroImage } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  article={true}
  pubDate={pubDate}
  updatedDate={updatedDate}
  author={author}
>
  <Breadcrumb items={[
    { label: '首页', href: '/' },
    { label: '全部文章', href: '/blog/' },
    { label: category, href: `/category/${category}/` },
    { label: title, href: Astro.url.pathname },
  ]} />

  <article class="max-w-3xl mx-auto">
    <header class="mb-8">
      <span class="inline-block text-sm font-medium text-primary bg-primary/10 px-3 py-1 rounded-full mb-4">
        {category}
      </span>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">{title}</h1>
      <div class="flex items-center gap-4 text-sm text-gray-500">
        <span>作者：{author}</span>
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
    </header>

    {heroImage && (
      <div class="mb-8 rounded-xl overflow-hidden">
        <img src={heroImage} alt={title} class="w-full" loading="eager" />
      </div>
    )}

    <AdSlot slot="in-article" />

    <div class="prose prose-lg max-w-none mt-8">
      <slot />
    </div>

    <AdSlot slot="in-article" />

    {tags.length > 0 && (
      <div class="mt-8 pt-6 border-t border-gray-100">
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="text-xs bg-gray-100 text-gray-600 px-3 py-1 rounded-full">#{tag}</span>
          ))}
        </div>
      </div>
    )}
  </article>
</BaseLayout>
