---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags?: string[];
  author?: string;
  heroImage?: string;
}

const { title, description, pubDate, updatedDate, category, tags = [], author = 'LifeTips', heroImage } = Astro.props;

const path = Astro.url.pathname;
const lang = path.startsWith('/zh/') ? 'zh' : 
             path.startsWith('/ja/') ? 'ja' : 
             path.startsWith('/ko/') ? 'ko' : 
             path.startsWith('/de/') ? 'de' : 'en';

const translations = {
  zh: { home: '首页', allPosts: '全部文章', author: '作者' },
  en: { home: 'Home', allPosts: 'All Posts', author: 'Author' },
  ja: { home: 'ホーム', allPosts: 'すべての記事', author: '著者' },
  ko: { home: '홈', allPosts: '모든 글', author: '저자' },
  de: { home: 'Startseite', allPosts: 'Alle Beiträge', author: 'Autor' },
};

const t = translations[lang];
const locale = lang === 'zh' ? 'zh-CN' : lang === 'ja' ? 'ja-JP' : lang === 'ko' ? 'ko-KR' : lang === 'de' ? 'de-DE' : 'en-US';
const blogPath = lang === 'zh' ? '/zh/blog/' : lang === 'en' ? '/blog/' : `/${lang}/blog/`;
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  article={true}
  pubDate={pubDate}
  updatedDate={updatedDate}
  author={author}
>
  <Breadcrumb items={[
    { label: t.home, href: '/' },
    { label: t.allPosts, href: blogPath },
    { label: category, href: `/category/${category}/` },
    { label: title, href: Astro.url.pathname },
  ]} />

  <article class="max-w-3xl mx-auto">
    <header class="mb-8">
      <span class="inline-block text-sm font-medium text-primary bg-primary/10 px-3 py-1 rounded-full mb-4">
        {category}
      </span>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">{title}</h1>
      <div class="flex items-center gap-4 text-sm text-gray-500">
        <span>{t.author}：{author}</span>
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
    </header>

    {heroImage && (
      <div class="mb-8 rounded-xl overflow-hidden">
        <img src={heroImage} alt={title} class="w-full" loading="eager" />
      </div>
    )}

    <div class="prose prose-lg max-w-none mt-8">
      <slot />
    </div>

    {tags.length > 0 && (
      <div class="mt-8 pt-6 border-t border-gray-100">
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="text-xs bg-gray-100 text-gray-600 px-3 py-1 rounded-full">#{tag}</span>
          ))}
        </div>
      </div>
    )}
  </article>
</BaseLayout>
