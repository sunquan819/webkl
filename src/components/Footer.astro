---
import { getLangFromUrl, useTranslations, languages, defaultLang, BASE_PATH } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();

function getLocalizedUrl(path: string, targetLang: string): string {
  if (targetLang === defaultLang) {
    return BASE_PATH + path;
  }
  return BASE_PATH + '/' + targetLang + path;
}
---

<footer class="bg-gray-900 text-gray-400 mt-16">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">🌿</span>
          <span class="text-xl font-bold text-white">{t.siteName}</span>
        </div>
        <p class="text-sm leading-relaxed">{t.siteDesc}</p>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">{t.blog}</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={getLocalizedUrl('/blog/', lang)} class="hover:text-white transition-colors">{t.blog}</a></li>
          <li><a href={getLocalizedUrl('/about/', lang)} class="hover:text-white transition-colors">{t.about}</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Languages</h3>
        <ul class="space-y-2 text-sm">
          {Object.entries(languages).map(([code, info]) => (
            <li>
              <a href={getLocalizedUrl('/', code)} class:list={['hover:text-white transition-colors', code === lang ? 'text-white' : '']}>
                {info.flag} {info.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm">
      <p>&copy; {year} {t.siteName}. {t.copyright}.</p>
      <p class="mt-2 text-xs text-gray-500">{t.disclaimer}.</p>
    </div>
  </div>
</footer>