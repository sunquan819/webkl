---
import { getLangFromUrl, useTranslations, getLocalizedPath, languages } from '../i18n/utils';
import { url } from '../utils/url';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-400 mt-16">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">🌿</span>
          <span class="text-xl font-bold text-white">{t.siteName}</span>
        </div>
        <p class="text-sm leading-relaxed">
          {t.siteDesc}
        </p>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">{t.popularCategories}</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={url(getLocalizedPath('/category/财经投资/', lang))} class="hover:text-white transition-colors">📈 {t.categories.finance}</a></li>
          <li><a href={url(getLocalizedPath('/category/life-tips/', lang))} class="hover:text-white transition-colors">{t.categories.lifeTips}</a></li>
          <li><a href={url(getLocalizedPath('/category/health/', lang))} class="hover:text-white transition-colors">{t.categories.health}</a></li>
          <li><a href={url(getLocalizedPath('/category/home-storage/', lang))} class="hover:text-white transition-colors">{t.categories.homeStorage}</a></li>
          <li><a href={url(getLocalizedPath('/category/cooking/', lang))} class="hover:text-white transition-colors">{t.categories.cooking}</a></li>
          <li><a href={url(getLocalizedPath('/category/money-saving/', lang))} class="hover:text-white transition-colors">{t.categories.moneySaving}</a></li>
          <li><a href={url(getLocalizedPath('/category/travel/', lang))} class="hover:text-white transition-colors">{t.categories.travel}</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">{t.aboutUs}</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={url(getLocalizedPath('/about/', lang))} class="hover:text-white transition-colors">{t.about}</a></li>
          <li><a href={url(getLocalizedPath('/blog/', lang))} class="hover:text-white transition-colors">{t.blog}</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Languages</h3>
        <ul class="space-y-2 text-sm">
          {Object.entries(languages).map(([code, info]) => (
            <li>
              <a href={url(getLocalizedPath('/', code as keyof typeof languages))} class:list={['hover:text-white transition-colors', code === lang ? 'text-white' : '']}>
                {info.flag} {info.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm">
      <p>&copy; {year} {t.siteName}. {t.copyright}.</p>
      <p class="mt-2 text-xs text-gray-500">{t.disclaimer}.</p>
    </div>
  </div>
</footer>